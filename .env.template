# Bootstrap settings only.
# Runtime trading / model / exchange / prompt configuration is managed in
# /console/config and stored in trading_data.db.

# Console login password.
ADMIN_PASSWORD=123456

# JWT signing secret.
JWT_SECRET=change-this-jwt-secret
