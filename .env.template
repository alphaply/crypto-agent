# Bootstrap settings only.
# Runtime trading / model / exchange / prompt configuration is managed in
# /console/config and stored in trading_data.db.

# Console login password.
ADMIN_PASSWORD=123456
# JWT signing secret.
JWT_SECRET=change-this-jwt-secret
JWT_EXPIRE_HOURS=8
# Encryption key for secrets stored in SQLite.
CONFIG_MASTER_KEY=change-this-config-master-key
# Server bootstrap settings.
HOST_PORT=31421
APP_PORT=7860
# For single-process runs only. Docker Compose overrides this and starts a
# dedicated scheduler container.
RUN_SCHEDULER_IN_WEB=true
SCHEDULER_MAX_WORKERS=2
TIMEZONE=Asia/Shanghai
