# Encryption key for secrets stored in SQLite.
CONFIG_MASTER_KEY=change-this-config-master-key

# Server bootstrap settings.
PORT=7860
RUN_SCHEDULER_IN_WEB=true
TIMEZONE=Asia/Shanghai
